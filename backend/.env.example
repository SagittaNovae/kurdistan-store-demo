APP_NAME="Kurdistan Store Demo"
APP_ENV=local
APP_KEY=                          # Run: php artisan key:generate
APP_DEBUG=true
APP_DEBUG_ALLOWED_IPS=
APP_URL=http://localhost:8000
APP_ADMIN_URL=admin
APP_TIMEZONE=Asia/Baghdad

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_CURRENCY=IQD

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kurdistan_store_demo
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=

# file/database drivers work without Redis. Switch to redis for full dev parity.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=array
CACHE_PREFIX=ks_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────
# Demo default: emails are written to storage/logs/laravel.log.
# Switch to smtp and configure MAIL_HOST/PORT/USERNAME/PASSWORD for real delivery.
MAIL_MAILER=log
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

MAIL_FROM_ADDRESS=noreply@demo.local
MAIL_FROM_NAME="Kurdistan Store Demo"
ADMIN_MAIL_ADDRESS=admin@demo.local
ADMIN_MAIL_NAME="Kurdistan Store Demo"
CONTACT_MAIL_ADDRESS=contact@demo.local
CONTACT_MAIL_NAME="Kurdistan Store Demo"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_HOST=localhost
VITE_PORT=

# ─── Kurdistan Store ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:8000

SHIPPING_FLAT_RATE=2500
SHIPPING_FREE_THRESHOLD=50000

API_RATE_LIMIT=120
AUTH_RATE_LIMIT=10

SEO_SITE_NAME="Kurdistan Store Demo"
SEO_DEFAULT_DESCRIPTION="Shop online — portfolio demo application."

# ─── Phone validation ─────────────────────────────────────────────
PHONE_DEFAULT_COUNTRY=+964
PHONE_E164_PATTERN=^\+9647\d{9}$
